generator client {
  provider = "prisma-client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  isAdmin   Boolean    @default(false)
  playerId  String?    @unique
  player    Player?    @relation(fields: [playerId], references: [id], onDelete: SetNull)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Player {
  id         String    @id @default(cuid())
  username   String    @unique
  avatarUrl  String?
  active     Boolean   @default(true)
  archivedAt DateTime?
  user       User?

  statValues        StatValue[]
  suggestions       Suggestion[]
  proposedSuggestions Suggestion[] @relation("SuggestionProposer")
  votes             Vote[]
  comments          Comment[]
  commentsAuthored  Comment[]      @relation("CommentAuthor")
  evidence          Evidence[]
  reviewSessions    ReviewSession[]
  editingSessions   ReviewSession[] @relation("ReviewEditor")
  reviewParticipants ReviewParticipant[] @relation("ReviewParticipant")
  historyEdits      StatHistory[]  @relation("ChangedBy")
  statVisibility    StatVisibility[]
  lockOverrides     StatLockOverride[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id    String @id @default(cuid())
  code  String @unique
  label String
  emoji String

  stats             Stat[]
  evidenceCategories EvidenceCategory[]

  createdAt DateTime @default(now())
}

model Stat {
  id         String @id @default(cuid())
  code       String @unique
  label      String
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  statValues       StatValue[]
  suggestions      Suggestion[]
  sessionStats     ReviewSessionStat[]
  visibility       StatVisibility[]
  prerequisites    StatPrerequisite[] @relation("GatedStat")
  requiredBy       StatPrerequisite[] @relation("RequiredStat")
  lockOverrides    StatLockOverride[]

  createdAt DateTime @default(now())
}

// Presence of a row with hidden=true hides the stat for that player; no row = visible.
model StatVisibility {
  id       String  @id @default(cuid())
  statId   String
  stat     Stat    @relation(fields: [statId], references: [id], onDelete: Cascade)
  playerId String
  player   Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  hidden   Boolean @default(true)

  createdAt DateTime @default(now())

  @@unique([statId, playerId])
}

// Multiple rows per statId = AND logic. Exactly one of requiredStatId/requiredCategoryId is set.
model StatPrerequisite {
  id                 String  @id @default(cuid())
  statId             String
  stat               Stat    @relation("GatedStat", fields: [statId], references: [id], onDelete: Cascade)
  requiredStatId     String?
  requiredStat       Stat?   @relation("RequiredStat", fields: [requiredStatId], references: [id], onDelete: Cascade)
  requiredCategoryId String?
  comparator         String  @default(">=")
  thresholdValue     Int

  createdAt DateTime @default(now())
}

// Manual per-stat-per-player override; supersedes computed prerequisite result.
model StatLockOverride {
  id          String @id @default(cuid())
  statId      String
  stat        Stat   @relation(fields: [statId], references: [id], onDelete: Cascade)
  playerId    String
  player      Player @relation(fields: [playerId], references: [id], onDelete: Cascade)
  forcedState String // "locked" | "unlocked"

  createdAt DateTime @default(now())

  @@unique([statId, playerId])
}

model StatValue {
  id        String @id @default(cuid())
  statId    String
  stat      Stat   @relation(fields: [statId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  value     Int     @default(0)
  notes     String?

  history   StatHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([statId, playerId])
}

model StatHistory {
  id         String @id @default(cuid())
  statValueId String
  statValue  StatValue @relation(fields: [statValueId], references: [id], onDelete: Cascade)

  oldValue   Int
  newValue   Int
  reason     String?
  changedById String
  changedBy  Player  @relation("ChangedBy", fields: [changedById], references: [id])
  source     String  // "admin_edit" | "suggestion" | "review_cycle"

  createdAt DateTime @default(now())
}

// The ONLY mechanism by which a stat value changes. delta is constrained to
// -2/-1/1/2 in app logic; proposedById must differ from playerId (subject).
model Suggestion {
  id           String  @id @default(cuid())
  playerId     String // subject
  player       Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  proposedById String
  proposedBy   Player  @relation("SuggestionProposer", fields: [proposedById], references: [id], onDelete: Cascade)
  statId       String
  stat         Stat    @relation(fields: [statId], references: [id], onDelete: Cascade)

  delta     Int
  reason    String
  testimony String? // written witness account — substitutes for evidence when something was seen IRL with no media
  status    String // "pending" | "approved" | "rejected"

  votes    Vote[]
  evidence SuggestionEvidence[]

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  resolvedAt DateTime?
}

model SuggestionEvidence {
  suggestionId String
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  evidenceId   String
  evidence     Evidence   @relation(fields: [evidenceId], references: [id], onDelete: Cascade)

  @@id([suggestionId, evidenceId])
}

model Vote {
  id           String @id @default(cuid())
  suggestionId String
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  userId       String
  user         Player     @relation(fields: [userId], references: [id], onDelete: Cascade)

  choice       String  // "yes" | "no"

  createdAt DateTime @default(now())

  @@unique([suggestionId, userId])
}

model Comment {
  id       String @id @default(cuid())
  playerId String
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  authorId String
  author   Player @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  body     String

  createdAt DateTime @default(now())

  @@index([playerId])
}

// Evidence board post. Only the subject posts about themselves (playerId = poster = subject).
model Evidence {
  id                 String  @id @default(cuid())
  playerId           String
  player             Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  mediaUrl           String?
  mediaType          String? // "image" | "video"
  cloudinaryPublicId String?
  caption            String?
  captionHidden      Boolean @default(false)

  categories  EvidenceCategory[]
  suggestions SuggestionEvidence[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EvidenceCategory {
  evidenceId String
  evidence   Evidence @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([evidenceId, categoryId])
}

model ReviewCycle {
  id        String @id @default(cuid())
  label     String
  status    String  // "draft" | "in_progress" | "ready_to_present" | "revealed"

  sessions  ReviewSession[]

  createdAt DateTime @default(now())
  revealedAt DateTime?
}

model ReviewSession {
  id            String @id @default(cuid())
  cycleId       String
  cycle         ReviewCycle @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  targetPlayerId String
  targetPlayer  Player      @relation(fields: [targetPlayerId], references: [id], onDelete: Cascade)

  editorId String?
  editor   Player? @relation("ReviewEditor", fields: [editorId], references: [id], onDelete: SetNull)

  status        String  // "pending" | "in_progress" | "submitted"
  lastEditedById String?
  submittedAt   DateTime?

  stats        ReviewSessionStat[]
  participants ReviewParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cycleId, targetPlayerId])
}

model ReviewParticipant {
  id        String @id @default(cuid())
  sessionId String
  session   ReviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  playerId String
  player   Player   @relation("ReviewParticipant", fields: [playerId], references: [id], onDelete: Cascade)

  role String  // "editor" | "reviewer"

  createdAt DateTime @default(now())

  @@unique([sessionId, playerId])
}

model ReviewSessionStat {
  id        String @id @default(cuid())
  sessionId String
  session   ReviewSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  statId    String
  stat      Stat   @relation(fields: [statId], references: [id], onDelete: Cascade)

  oldValue      Int
  proposedValue Int?
  note          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
